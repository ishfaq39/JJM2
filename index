function csvParse(text){
 const rows=[]; let row=[], cur='', q=false;
 for(let i=0;i<text.length;i++){ const ch=text[i], nx=text[i+1];
   if(ch=='"'){ if(q && nx=='"'){cur+='"';i++} else q=!q; }
   else if(ch==',' && !q){ row.push(cur); cur=''; }
   else if((ch=='\n'||ch=='\r') && !q){ if(ch=='\r'&&nx=='\n')i++; row.push(cur); if(row.some(x=>x.trim()!=='')) rows.push(row); row=[]; cur=''; }
   else cur+=ch;
 }
 row.push(cur); if(row.some(x=>x.trim()!=='')) rows.push(row);
 return rows;
}
function norm(s){return String(s||'').toLowerCase().replace(/[^a-z0-9]/g,'');}
function findHeader(rows){
 const aliases={name:['nameofparticipant','participantname','fullname','name','participant'], gender:['gender','sex'], designation:['designation','desig','post','position'], department:['department','organisation','organization','office','dept','organisationname'], mobile:['mobileno','mobilenumber','mobile','phoneno','phone','contactno','contact','whatsapp'], state:['statename','state'], email:['emailid','email','mailid'], district:['district','districtname']};
 let best=null;
 for(let i=0;i<Math.min(rows.length,40);i++){ let map={}, score=0;
   rows[i].forEach((h,idx)=>{ let n=norm(h); Object.keys(aliases).forEach(k=>{ if(aliases[k].some(a=>n.includes(a))){ if(map[k]===undefined){map[k]=idx;score++;} } }); });
   if(map.name!==undefined && score>=2){ if(!best||score>best.score) best={row:i,map,score}; }
 }
 return best?{row:best.row,map:best.map}:null;
}
function countRows(rows, h){
 if(!h) return {count:0, data:[]};
 let out=[]; const m=h.map;
 for(let r=h.row+1;r<rows.length;r++){ const row=rows[r]||[]; const name=(row[m.name]||'').trim();
   if(!name || /^\d+$/.test(name) || /^s\.?no\.?$/i.test(name) || /^total/i.test(name)) continue;
   const anyOther=row.some((v,idx)=>idx!==m.name && String(v||'').trim()!=='');
   if(!anyOther) continue;
   out.push({name, gender:(row[m.gender]||'').trim(), designation:(row[m.designation]||'').trim(), department:(row[m.department]||'').trim(), mobile:(row[m.mobile]||'').trim(), state:(row[m.state]||'').trim(), email:(row[m.email]||'').trim()});
 }
 return {count:out.length,data:out};
}
async function tryFetchCsv(url){
 try{
   const res=await fetch(url,{cache:'no-store',redirect:'follow'});
   if(!res.ok) return null;
   const t=await res.text();
   const head=t.slice(0,500).toLowerCase();
   if(head.includes('<!doctype html')||head.includes('<html')) return null;
   if(!t||t.length<5) return null;
   return t;
 }catch(e){ return null; }
}
async function fetchCourse(c){
 if(!c.sheetId || c.sheetId.includes('...')) return c;
 const id=c.sheetId;
 const endpoints=[
   `https://docs.google.com/spreadsheets/d/${id}/export?format=csv`,
   `https://docs.google.com/spreadsheets/d/${id}/export?format=csv&gid=0`,
   `https://docs.google.com/spreadsheets/d/${id}/gviz/tq?tqx=out:csv&gid=0`,
   `https://docs.google.com/spreadsheets/d/${id}/gviz/tq?tqx=out:csv`
 ];
 let bestRows=null,bestHeader=null,bestCount=-1,lastError='';
 for(const url of endpoints){
   const text=await tryFetchCsv(url);
   if(!text){ lastError='No CSV from '+url.split('?')[0]; continue; }
   const rows=csvParse(text);
   const header=findHeader(rows);
   if(!header){ lastError='Header not found'; continue; }
   const counted=countRows(rows,header);
   if(counted.count>bestCount){ bestCount=counted.count; bestRows=counted.data; bestHeader=header; }
   if(counted.count>0) break;
 }
 if(bestHeader===null){ c.status= lastError.startsWith('Header')?'Header not found':'Fetch error'; c.registrations=0; c.rows=[]; if(lastError) c.error=lastError; return c; }
 c.registrations=Math.max(0,bestCount); c.rows=bestRows||[]; c.status=c.registrations>0?'Loaded':'No registrations'; return c;
}

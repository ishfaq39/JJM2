function cleanState(s){s=String(s||'').trim(); if(!s) return ''; const u=s.toUpperCase(); if(u==='J&K'||u.includes('JAMMU')) return 'Jammu & Kashmir'; if(u.includes('ODISHA')) return 'Odisha'; if(u.includes('WEST BENGAL')) return 'West Bengal'; if(u.includes('CHHAT')) return 'Chhattisgarh'; return s.replace(/\w\S*/g,t=>t[0].toUpperCase()+t.slice(1).toLowerCase());}
function parseDate(s){let d=new Date(s); if(isNaN(d)){let m=String(s).match(/(\d{1,2})-([A-Za-z]{3})-(\d{4})/); if(m) d=new Date(`${m[1]} ${m[2]} ${m[3]}`);} return isNaN(d)?new Date('2999-01-01'):d;}
